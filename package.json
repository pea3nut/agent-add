{
  "name": "@pea3nut/agent-get",
  "version": "0.0.0",
  "description": "Cross-host AI Agent Pack installer — install MCP, Skill, Prompt, Command, Sub-agent in one command",
  "bin": {
    "agent-get": "bin/agent-get.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run tests/unit tests/integration",
    "test:contract": "vitest run tests/contract",
    "test:integration": "vitest run tests/integration",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "agent",
    "mcp",
    "cursor",
    "claude"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/select": "^5.1.2",
    "commander": "^14.0.3",
    "smol-toml": "^1.6.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
